{
  "info": {
    "name": "CircleGuard E2E",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Flujo 1 - Login",
      "item": [
        {
          "name": "Login super_admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response tiene token', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property('token');",
                  "    pm.environment.set('authToken', json.token);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"username\": \"super_admin\", \"password\": \"password\"}"
            },
            "url": {
              "raw": "{{authServiceUrl}}/api/v1/auth/login",
              "host": ["{{authServiceUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Flujo 2 - Registro de visitante",
      "item": [
        {
          "name": "Registrar visitante",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 o 201', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "pm.test('Response tiene anonymousId', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property('anonymousId');",
                  "    pm.environment.set('anonymousId', json.anonymousId);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"Visitante E2E\", \"email\": \"e2e@circleguard.test\", \"reason_for_visit\": \"Prueba automatizada E2E\"}"
            },
            "url": {
              "raw": "{{identityServiceUrl}}/api/v1/identities/visitor",
              "host": ["{{identityServiceUrl}}"],
              "path": ["api", "v1", "identities", "visitor"]
            }
          }
        }
      ]
    },
    {
      "name": "Flujo 3 - Cuestionario y encuesta",
      "item": [
        {
          "name": "Crear cuestionario",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 o 201', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "pm.test('Response tiene id', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property('id');",
                  "    pm.environment.set('questionnaireId', json.id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"title\": \"Cuestionario E2E\", \"description\": \"Generado por pruebas automatizadas\", \"version\": 1, \"questions\": [{\"text\": \"¿Tiene fiebre?\", \"type\": \"YES_NO\", \"orderIndex\": 0}, {\"text\": \"¿Tiene tos?\", \"type\": \"YES_NO\", \"orderIndex\": 1}]}"
            },
            "url": {
              "raw": "{{formServiceUrl}}/api/v1/questionnaires",
              "host": ["{{formServiceUrl}}"],
              "path": ["api", "v1", "questionnaires"]
            }
          }
        },
        {
          "name": "Activar cuestionario",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 o 204', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 204]);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{formServiceUrl}}/api/v1/questionnaires/{{questionnaireId}}/activate",
              "host": ["{{formServiceUrl}}"],
              "path": ["api", "v1", "questionnaires", "{{questionnaireId}}", "activate"]
            }
          }
        },
        {
          "name": "Obtener cuestionario activo",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response es cuestionario valido', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property('id');",
                  "    pm.expect(json.isActive).to.be.true;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{formServiceUrl}}/api/v1/questionnaires/active",
              "host": ["{{formServiceUrl}}"],
              "path": ["api", "v1", "questionnaires", "active"]
            }
          }
        },
        {
          "name": "Enviar encuesta de salud",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 o 201', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"anonymousId\": \"{{anonymousId}}\", \"hasFever\": false, \"hasCough\": false, \"otherSymptoms\": \"\", \"responses\": {}}"
            },
            "url": {
              "raw": "{{formServiceUrl}}/api/v1/surveys",
              "host": ["{{formServiceUrl}}"],
              "path": ["api", "v1", "surveys"]
            }
          }
        }
      ]
    },
