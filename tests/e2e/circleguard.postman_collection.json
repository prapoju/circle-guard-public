      "item": [
        {
          "name": "Enviar encuesta con sintomas (PENDING)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 o 201', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "pm.test('Survey guardada con id', function () {",
                  "    var json = pm.response.json();",
