              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response es JSON', function () {",
                  "    pm.response.to.be.json;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{dashboardServiceUrl}}/api/v1/analytics/health-board",
              "host": ["{{dashboardServiceUrl}}"],
              "path": ["api", "v1", "analytics", "health-board"]
            }
          }
        }
      ]
    },
    {
      "name": "Flujo 5 - Generar QR",
      "item": [
        {
          "name": "Generar token QR",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response tiene token QR', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property('qrToken');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{authServiceUrl}}/api/v1/auth/qr/generate",
              "host": ["{{authServiceUrl}}"],
              "path": ["api", "v1", "auth", "qr", "generate"]
            }
          }
        }
      ]
    }
  ]
}
