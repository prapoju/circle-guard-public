    {
      "name": "Flujo 5 - Generar QR",
      "item": [
        {
          "name": "Generar token QR",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response tiene qrToken y expiresIn', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property('qrToken');",
                  "    pm.expect(json).to.have.property('expiresIn');",
                  "    pm.environment.set('qrToken', json.qrToken);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
