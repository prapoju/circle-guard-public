                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"anonymousId\": \"{{anonymousId}}\", \"hasFever\": true, \"hasCough\": true, \"otherSymptoms\": \"Dolor de cabeza, fatiga\", \"validationStatus\": \"PENDING\", \"responses\": {}}"
            },
            "url": {
              "raw": "{{formServiceUrl}}/api/v1/surveys",
              "host": ["{{formServiceUrl}}"],
              "path": ["api", "v1", "surveys"]
            }
          }
        },
        {
          "name": "Obtener certificados pendientes",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Lista de pendientes no esta vacia', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.be.an('array');",
                  "    pm.expect(json.length).to.be.above(0);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{formServiceUrl}}/api/v1/certificates/pending",
              "host": ["{{formServiceUrl}}"],
              "path": ["api", "v1", "certificates", "pending"]
            }
          }
        },
        {
          "name": "Validar certificado como APPROVED",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{formServiceUrl}}/api/v1/certificates/{{certSurveyId}}/validate?status=APPROVED&adminId=00000000-0000-0000-0000-000000000001",
              "host": ["{{formServiceUrl}}"],
              "path": ["api", "v1", "certificates", "{{certSurveyId}}", "validate"],
              "query": [
                { "key": "status", "value": "APPROVED" },
                { "key": "adminId", "value": "00000000-0000-0000-0000-000000000001" }
              ]
            }
          }
        }
