              "host": ["{{identityServiceUrl}}"],
              "path": ["api", "v1", "identities", "visitor"]
            }
          }
        },
        {
          "name": "Generar token de handoff",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response tiene token y handoffPayload', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property('token');",
                  "    pm.expect(json).to.have.property('handoffPayload');",
                  "    pm.expect(json.handoffPayload).to.include('HANDOFF_TOKEN');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
