#!/usr/bin/env groovy

pipeline {

    agent {
        kubernetes {
            defaultContainer 'jdk21'
            yaml '''
            apiVersion: v1
            kind: Pod
            spec:
              containers:
                - name: jdk21
                  image: eclipse-temurin:21-jdk
                  command: ["sleep"]
                  args: ["infinity"]
                - name: docker
                  image: docker:24-dind
                  securityContext:
                    privileged: true
                  env:
                    - name: DOCKER_TLS_CERTDIR
                      value: ""
                  command: ["dockerd-entrypoint.sh"]
                  args: ["--host=tcp://0.0.0.0:2375","--host=unix:///var/run/docker.sock"]
            '''
        }
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Compile') {
            steps {
                sh 'chmod +x gradlew && ./gradlew --no-daemon :services:circleguard-gateway-service:compileJava'
            }
        }

        stage('Unit Tests') {
            steps {
                sh './gradlew --no-daemon :services:circleguard-gateway-service:test'
            }
            post {
                always {
                    echo 'Unit tests completed'
                }
            }
        }

        stage('Integration Tests') {
            steps {
                sh './gradlew --no-daemon :services:circleguard-gateway-service:integrationTest'
            }
        }

        stage('Build & Push Image') {
            steps {
                sh './gradlew --no-daemon :services:circleguard-gateway-service:bootJar'
                container('docker') {
                    withCredentials([usernamePassword(credentialsId: 'dockerhub-credentials', usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                        sh 'docker login -u $DOCKER_USER -p $DOCKER_PASS'
                        sh 'docker build -t prapoju/circleguard-gateway-service:dev services/circleguard-gateway-service/'
                        sh 'docker push prapoju/circleguard-gateway-service:dev'
                    }
                }
            }
        }
    }

    post {
        success {
            echo 'circleguard-gateway-service pipeline completed successfully!'
        }
        failure {
            echo 'circleguard-gateway-service pipeline failed. Check the logs.'
        }
    }
}
