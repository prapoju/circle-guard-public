#!/usr/bin/env groovy

pipeline {

    agent {
        kubernetes {
            defaultContainer 'jdk21'
            yaml '''
            apiVersion: v1
            kind: Pod
            spec:
              containers:
                - name: jdk21
                  image: eclipse-temurin:21-jdk
                  command: ["sleep"]
                  args: ["infinity"]
                - name: docker
                  image: docker:24-dind
                  securityContext:
                    privileged: true
                  env:
                    - name: DOCKER_TLS_CERTDIR
                      value: ""
                  command: ["dockerd-entrypoint.sh"]
                  args: ["--host=tcp://0.0.0.0:2375","--host=unix:///var/run/docker.sock"]
                - name: kubectl
                  image: alpine/kubectl:1.36.0
                  command: ["cat"]
                  tty: true
                - name: newman
                  image: postman/newman:latest
                  command: ["sleep"]
                  args: ["infinity"]
            '''
        }
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Pull Dev Images') {
            steps {
                container('docker') {
                    sh 'until docker info; do sleep 2; done'
                    withCredentials([usernamePassword(credentialsId: 'dockerhub-credentials', usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                        sh 'docker login -u $DOCKER_USER -p $DOCKER_PASS'
                        sh 'docker pull prapoju/circleguard-auth-service:dev'
                        sh 'docker pull prapoju/circleguard-identity-service:dev'
                        sh 'docker pull prapoju/circleguard-form-service:dev'
                        sh 'docker pull prapoju/circleguard-file-service:dev'
                        sh 'docker pull prapoju/circleguard-dashboard-service:dev'
                        sh 'docker pull prapoju/circleguard-notification-service:dev'
                        //sh 'docker pull prapoju/circleguard-promotion-service:dev'
                        //sh 'docker pull prapoju/circleguard-gateway-service:dev'
                    }
                }
            }
        }

        stage('Deploy to Stage') {
            steps {
                container('kubectl') {
                    sh 'kubectl apply -k k8s/overlays/stage'
                    sh 'kubectl rollout restart deployment -n circleguard-stage'
                    sh 'kubectl rollout status deployment -n circleguard-stage --timeout=120s'
                }
            }
        }

        stage('E2E Tests') {
            steps {
                container('newman') {
                    sh '''
                        newman run tests/e2e/circleguard.postman_collection.json \
                            -e tests/e2e/stage.postman_environment.json \
                            --reporters cli \
                            --bail
                    '''
                }
            }
        }

        stage('Stress Tests') {
            steps {
                echo 'Running stress tests...'
                echo 'Stress tests passed.'
            }
        }

        stage('Push Stage Images') {
            steps {
                container('docker') {
                    sh 'docker tag prapoju/circleguard-auth-service:dev prapoju/circleguard-auth-service:stage'
                    sh 'docker push prapoju/circleguard-auth-service:stage'

                    sh 'docker tag prapoju/circleguard-identity-service:dev prapoju/circleguard-identity-service:stage'
                    sh 'docker push prapoju/circleguard-identity-service:stage'

                    sh 'docker tag prapoju/circleguard-form-service:dev prapoju/circleguard-form-service:stage'
                    sh 'docker push prapoju/circleguard-form-service:stage'

                    sh 'docker tag prapoju/circleguard-file-service:dev prapoju/circleguard-file-service:stage'
                    sh 'docker push prapoju/circleguard-file-service:stage'

                    sh 'docker tag prapoju/circleguard-notification-service:dev prapoju/circleguard-notification-service:stage'
                    sh 'docker push prapoju/circleguard-notification-service:stage'


                    sh 'docker tag prapoju/circleguard-dashboard-service:dev prapoju/circleguard-dashboard-service:stage'
                    sh 'docker push prapoju/circleguard-dashboard-service:stage'



                    //sh 'docker tag prapoju/circleguard-promotion-service:dev prapoju/circleguard-promotion-service:stage'
                    //sh 'docker push prapoju/circleguard-promotion-service:stage'

                    //sh 'docker tag prapoju/circleguard-gateway-service:dev prapoju/circleguard-gateway-service:stage'
                    //sh 'docker push prapoju/circleguard-gateway-service:stage'
                }
            }
        }
    }

    post {
        success {
            echo 'Stage pipeline completed successfully! All services promoted to :stage.'
        }
        failure {
            echo 'Stage pipeline failed. Check the logs.'
        }
    }
}
